apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: http://{{ prometheus_name }}:9090
    isDefault: true
    editable: false

  - name: Loki
    type: loki
    access: proxy
    url: http://{{ loki_name }}:3100
    editable: false
    jsonData:
      maxLines: 1000 